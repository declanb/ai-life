# Required for Vercel integration
VERCEL_TOKEN=your_vercel_token_here
VERCEL_TEAM_ID=your_team_id_here

# Required for Dublin Bus real-time data via TFI GTFS-Realtime API
# Register at https://developer.nationaltransport.ie/ and subscribe to GTFS-R API
# API key activates after ~15 minutes once subscription is confirmed
TFI_API_KEY=your_tfi_api_key_here

# Deployment environment — auto-set by Vercel to "production" | "preview" | "development"
ENVIRONMENT=development

# CORS — comma-separated list of origins allowed to call this API.
# In Vercel prod, set this to your web + docs deployment URLs (and any custom domain).
# NEVER use "*" — the API uses credentialed requests.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001

# Sentry — leave blank in dev to disable error reporting.
# Get DSN from https://sentry.io/settings/<org>/projects/<project>/keys/
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
