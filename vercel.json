{
    "version": 2,
    "builds": [
        {
            "src": "apps/web/package.json",
            "use": "@vercel/next"
        },
        {
            "src": "apps/api/index.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/api/v1/(.*)",
            "dest": "apps/api/index.py"
        },
        {
            "src": "/(.*)",
            "dest": "apps/web/$1"
        }
    ],
    "crons": [
        {
            "path": "/api/v1/property-finder/cron/refresh",
            "schedule": "0 8 * * *"
        }
    ]
}
